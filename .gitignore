# Keep core application source, public assets, tests, and database seeders/migrations
!app/
!app/**
!public/
!public/**
!writable/
!writable/index.html
!writable/**/index.html

# Exclude local public helper scripts after public assets are re-included
/public/check.php
/public/setup_dummy.php
